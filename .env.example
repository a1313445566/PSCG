# 服务器配置
SERVER_PORT=3001

# API 地址（前端使用）
# 开发环境: http://localhost:3001/api
# 生产环境: http://your-server-ip:3001/api
VITE_API_URL=http://localhost:3001/api

# 签名密钥（请替换为实际密钥）
# 生成密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SIGNATURE_SECRET=your-secret-key-here
VITE_SIGNATURE_SECRET=your-secret-key-here

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=pscg
