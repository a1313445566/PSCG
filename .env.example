# 服务器配置
SERVER_PORT=3001

# API 地址配置
# 开发环境: http://localhost:3001/api
# 生产环境: /api（推荐，使用相对路径）
#   - 支持 Cloudflare tunnel
#   - 支持反向代理（Nginx、Caddy）
#   - 自动适应 HTTPS/HTTP
#   - 无需修改配置即可部署到不同域名
VITE_API_URL=/api

# 签名密钥（请替换为实际密钥）
# 生成密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SIGNATURE_SECRET=your-secret-key-here
VITE_SIGNATURE_SECRET=your-secret-key-here

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=pscg
# JWT 配置（安全修复：禁止硬编码密钥）
# 生成密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-hereb
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-secret-key-here
JWT_REFRESH_EXPIRES_IN=7d
