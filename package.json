{
  "name": "web2.0",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.cjs",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.example.quizapp",
    "productName": "小学刷题闯关系统",
    "directories": {
      "output": "electron-dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@vueup/vue-quill": "^1.2.0",
    "@vueuse/core": "^14.2.1",
    "cors": "^2.8.5",
    "element-plus": "^2.13.3",
    "express": "^4.18.2",
    "mime": "^4.1.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "pinia": "^3.0.4",
    "sqlite3": "^5.1.7",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
