{
  "project": {
    "name": "web2.0",
    "type": "fullstack",
    "framework": "vue",
    "backend": "express",
    "database": "sqlite"
  },
  "scripts": {
    "dev": "npm run dev",
    "build": "npm run build",
    "start": "npm run server",
    "preview": "npm run preview"
  },
  "ports": {
    "frontend": 5173,
    "backend": 3001
  },
  "env": {
    "development": {
      "VITE_API_URL": "http://localhost:3001/api"
    },
    "production": {
      "VITE_API_URL": "http://10.78.127.30:3001/api"
    }
  },
  "paths": {
    "src": "src",
    "dist": "dist",
    "backend": "server.cjs",
    "routes": "routes",
    "services": "services",
    "database": "quiz.db"
  },
  "dependencies": {
    "frontend": [
      "vue",
      "vue-router",
      "pinia",
      "element-plus",
      "echarts",
      "@vueup/vue-quill"
    ],
    "backend": [
      "express",
      "sqlite3",
      "cors",
      "compression",
      "multer"
    ]
  },
  "proxy": {
    "/api": {
      "target": "http://localhost:3001",
      "changeOrigin": true
    }
  },
  "rules": {
    "deployment": [
      "每次修复完成需要重构静态页面: npm run build",
      "如果修改了后端需要重启PM2服务器: pm2 restart PSCG"
    ]
  }
}
